[include]
    path = "~/.config/catppuccin/delta/catppuccin.gitconfig"

[commit]
    gpgsign = true

[core]
    excludesfile = ~/.config/git/ignore
    pager = delta
    preloadindex = true
{{ if eq .chezmoi.os "windows" -}}
	eol = lf
	autocrlf = input
{{- end }}

[diff]
    colorMoved = default

[delta]
    features = catppuccin-mocha
    line-numbers = true
    navigate = true

{{ if eq .chezmoi.os "windows" -}}
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
{{- end }}

{{ if eq .chezmoi.os "darwin" -}}
[gpg]
    program = /opt/homebrew/bin/gpg
{{- end }}

[init]
    defaultbranch = main
    templateDir = ~/.config/git/template

[interactive]
    diffFilter = delta --color-only

[merge]
    ; conflictstyle = diff3
    tool = nvimdiff

[pull]
    rebase = true

[push]
    autosetupremote = true

[rebase]
    autoStash = true

[rerere]
    enabled = false

[status]
    branch = true
    showStash = true
    showUntrackedFiles = normal
    submoduleSummary = true

[user]
    name = Samyak Bardiya
    email = mail@samyakbardiya.dev

{{ if ne .chezmoi.os "windows" -}}

[includeIf "gitdir:~/work-ct/"]
    path = ~/.config/git/config_work_ct

[includeIf "gitdir:~/work-tp/"]
    path = ~/.config/git/config_work_tp

{{- else -}}

[includeIf "gitdir:%USERPROFILE%/work-ct/"]
    path = %USERPROFILE%/.config/git/config_work_ct

[includeIf "gitdir:%USERPROFILE%/work-tp/"]
    path = %USERPROFILE%/.config/git/config_work_tp

{{- end }}
