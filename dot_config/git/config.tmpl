{{- $file := joinPath .chezmoi.homeDir ".config/git/config" -}}
{{- $machineId := output "git" "config" "--file" $file "coderabbit.machineId" | trim -}}

[include]
    path = "~/.config/catppuccin/delta/catppuccin.gitconfig"

[commit]
    gpgsign = true

[core]
    excludesfile = ~/.config/git/ignore
    pager = delta
    preloadindex = true
{{- if eq .chezmoi.os "windows" -}}
    eol = lf
    autocrlf = input
{{- end }}

[coderabbit]
    machineId = {{ $machineId }}

[color]
    ui = true

[diff]
    colorMoved = default

[delta]
    features = catppuccin-mocha
    hyperlinks = true
    hyperlinks-file-link-format = lazygit-edit://{path}:{line}
    line-numbers = true
    navigate = true

[fetch]
    all = true
    prune = true
    pruneTags = true

{{- if eq .chezmoi.os "windows" -}}
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
{{- end }}

[gpg]
    format = ssh

{{ if eq .chezmoi.os "darwin" -}}
[gpg "ssh"]
    program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
{{- end }}

[init]
    defaultbranch = main
    templateDir = ~/.config/git/template

[interactive]
    diffFilter = delta --color-only

[merge]
    # conflictstyle = "diff3"
    tool = nvimdiff

[pull]
    rebase = true

[push]
    autosetupremote = true

[rebase]
    autoStash = true

[rerere]
    enabled = false

[status]
    branch = true
    showStash = true
    showUntrackedFiles = normal
    submoduleSummary = true

[user]
    name = Samyak Bardiya
    email = mail@samyakbardiya.dev
    signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHbpZRkQYWG2hMobXAgkcnWyYHB7YkZ6Q3173ksu67kn

[includeIf "gitdir:~/work-ct/"]
    path = ~/.config/git/config_work_ct

[includeIf "gitdir:~/work-tp/"]
    path = ~/.config/git/config_work_tp
